function startCodeTimer() {
    if (forgotState.timerInterval) { clearInterval(forgotState.timerInterval); }
    document.getElementById('btnResend').disabled = true;

    forgotState.timerInterval = setInterval(function() {
        var remaining = Math.max(0, forgotState.codeExpiry - Date.now());
        var minutes = Math.floor(remaining / 60000);
        var seconds = Math.floor((remaining % 60000) / 1000);
        document.getElementById('timerVal').textContent =
            String(minutes).padStart(2, '0') + ':' + String(seconds).padStart(2, '0');

        if (remaining <= 0) {
            clearInterval(forgotState.timerInterval);
            forgotState.timerInterval = null;
            document.getElementById('timerVal').textContent = 'Süre doldu!';
            document.getElementById('btnResend').disabled = false;
        }
    }, 1000);
}

async function handleResendCode() {
    hideForgotError('forgotCode');
    clearCodeInputs();
    var code = generateCode();
    forgotState.code = code;
    forgotState.codeExpiry = Date.now() + 3 * 60 * 1000;

    document.getElementById('btnResend').disabled = true;
    try {
        await emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, {
            to_email: forgotState.email,
            verification_code: code,
            app_name: 'Enerji Dedektifi - TÜBİTAK 4009'
        });
        showToast('Yeni doğrulama kodu gönderildi!', 'success');
        startCodeTimer();
    } catch (err) {
        showToast('Kod gönderilemedi. Lütfen tekrar deneyin.', 'error');
        document.getElementById('btnResend').disabled = false;
    }
}

function clearCodeInputs() {
    var inputs = document.querySelectorAll('#codeInputsWrap .code-input-box');
    inputs.forEach(function(inp) {
        inp.value = '';
        inp.classList.remove('error-shake');
    });
}

function getEnteredCode() {
    var code = '';
    var inputs = document.querySelectorAll('#codeInputsWrap .code-input-box');
    inputs.forEach(function(inp) { code += inp.value; });
    return code;
}

async function handleVerifyCode() {
    hideForgotError('forgotCode');
    var enteredCode = getEnteredCode();

    if (enteredCode.length !== 8) {
        showForgotError('forgotCode', 'Lütfen 8 haneli doğrulama kodunun tamamını girin.');
        return;
    }

    // Süre kontrolü
    if (Date.now() > forgotState.codeExpiry) {
        showForgotError('forgotCode', 'Doğrulama kodunun süresi doldu. Lütfen yeni kod gönderin.');
        document.getElementById('btnResend').disabled = false;
        return;
    }

    // Kod doğrulama
    if (enteredCode !== forgotState.code) {
        showForgotError('forgotCode', 'Girilen kod hatalı! Lütfen tekrar kontrol edin.');
        var inputs = document.querySelectorAll('#codeInputsWrap .code-input-box');
        inputs.forEach(function(inp) {
            inp.classList.add('error-shake');
            setTimeout(function() { inp.classList.remove('error-shake'); }, 500);
        });
        return;
    }

    // Kod doğru! Hesabı Supabase'den sil
    setForgotLoading('btnVerifyCode', true);
    try {
        await SB.deleteRows(TABLE_NAME, 'gmail=eq.' + encodeURIComponent(forgotState.email));

        setForgotLoading('btnVerifyCode', false);
        if (forgotState.timerInterval) {
            clearInterval(forgotState.timerInterval);
            forgotState.timerInterval = null;
        }
        showToast('Hesap başarıyla silindi!', 'success');
        goForgotStep(3);

    } catch (err) {
        var delErr = err.message || 'Hesap silme işlemi başarısız oldu.';
        showForgotError('forgotCode', 'Hesap silme hatası: ' + delErr);
        setForgotLoading('btnVerifyCode', false);
    }
}

function forgotGoToRegister() {
    closeForgotPassword();
    switchAuth('register');
    // Email alanını önceden doldur
    document.getElementById('regEmail').value = forgotState.email;
    showToast('Yeni hesabınızı oluşturabilirsiniz.', 'success');
}

/* ===== CODE INPUT BOX EVENTS ===== */
(function setupCodeInputs() {
    var inputs = document.querySelectorAll('#codeInputsWrap .code-input-box');
    inputs.forEach(function(inp, idx) {
        inp.addEventListener('input', function(e) {
            var val = this.value.replace(/[^0-9]/g, '');
            this.value = val ? val[0] : '';
            if (val && idx < inputs.length - 1) {
                inputs[idx + 1].focus();
            }
            // Otomatik doğrulama: tüm kutular doluysa
            if (getEnteredCode().length === 8) {
                // Kısa bir gecikme ile doğrula
                setTimeout(function() { handleVerifyCode(); }, 200);
            }
        });
        inp.addEventListener('keydown', function(e) {
            if (e.key === 'Backspace' && !this.value && idx > 0) {
                inputs[idx - 1].focus();
                inputs[idx - 1].value = '';
            }
            if (e.key === 'ArrowLeft' && idx > 0) { inputs[idx - 1].focus(); }
            if (e.key === 'ArrowRight' && idx < inputs.length - 1) { inputs[idx + 1].focus(); }
        });
        inp.addEventListener('paste', function(e) {
            e.preventDefault();
            var paste = (e.clipboardData || window.clipboardData).getData('text').replace(/[^0-9]/g, '');
            for (var i = 0; i < Math.min(paste.length, 8); i++) {
                if (inputs[i]) { inputs[i].value = paste[i]; }
            }
            var focusIdx = Math.min(paste.length, 7);
            inputs[focusIdx].focus();
            if (paste.length >= 8) {
                setTimeout(function() { handleVerifyCode(); }, 200);
            }
        });
    });
})();

/* Forgot modal overlay tıklama ile kapatma */
document.getElementById('forgotModal').addEventListener('click', function(e) {
    if (e.target === this) { closeForgotPassword(); }
});

/* Forgot email input enter key */
document.getElementById('forgotEmailInput').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') { handleForgotSendCode(); }
});
