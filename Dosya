/* ===== SUPABASE REST API ===== */
var SB = {
    authHeaders: function(contentType) {
        var h = { 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + SUPABASE_KEY };
        if (contentType) { h['Content-Type'] = contentType; }
        return h;
    },

    async getRows(table, query) {
        var url = SUPABASE_URL + '/rest/v1/' + table + '?' + (query || 'select=*');
        var res = await fetch(url, { headers: this.authHeaders() });
        if (!res.ok) { throw new Error(await this.parseErr(res)); }
        return res.json();
    },

    async insertRow(table, data) {
        var res = await fetch(SUPABASE_URL + '/rest/v1/' + table, {
            method: 'POST',
            headers: Object.assign({}, this.authHeaders('application/json'), { 'Prefer': 'return=representation' }),
            body: JSON.stringify(data)
        });
        if (!res.ok) { throw new Error(await this.parseErr(res)); }
        var rows = await res.json();
        return rows[0];
    },

    publicUrl: function(path) {
        return SUPABASE_URL + '/storage/v1/object/public/' + BUCKET_NAME + '/' + path;
    },

    async deleteRows(table, query) {
        var url = SUPABASE_URL + '/rest/v1/' + table + '?' + query;
        var res = await fetch(url, {
            method: 'DELETE',
            headers: Object.assign({}, this.authHeaders('application/json'), { 'Prefer': 'return=representation' })
        });
        if (!res.ok) { throw new Error(await this.parseErr(res)); }
        return res.json();
    },

    async parseErr(res) {
        try {
            var data = await res.json();
            if (data.message) { return data.message; }
            if (data.error) { return typeof data.error === 'string' ? data.error : JSON.stringify(data.error); }
            if (data.msg) { return data.msg; }
            return JSON.stringify(data);
        } catch (e) {
            return 'HTTP ' + res.status + ': ' + res.statusText;
        }
    }
};

/* ===== SIMPLE HASH (for password) ===== */
async function hashPassword(pass) {
    var encoder = new TextEncoder();
    var data = encoder.encode(pass + '_enerji_dedektifi_salt_2024');
    var hashBuffer = await crypto.subtle.digest('SHA-256', data);
    var hashArray = Array.from(new Uint8Array(hashBuffer));
    return hashArray.map(function(b) { return b.toString(16).padStart(2, '0'); }).join('');
}

