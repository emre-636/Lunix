function validateEmail(email) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
}

async function handleLogin() {
    hideAuthError('login');
    var email = document.getElementById('loginEmail').value.trim().toLowerCase();
    var pass = document.getElementById('loginPass').value;

    if (!email) { showAuthError('login', 'Lütfen Gmail adresinizi girin.'); return; }
    if (!validateEmail(email)) { showAuthError('login', 'Geçerli bir Gmail adresi girin.'); return; }
    if (!pass) { showAuthError('login', 'Lütfen şifrenizi girin.'); return; }

    setAuthLoading('btnLogin', true);
    try {
        var hashedPass = await hashPassword(pass);
        
        // Kullanıcıyı projeler tablosunda ara (gmail ve şifre ile)
        var users = await SB.getRows(TABLE_NAME, 'select=*&gmail=eq.' + encodeURIComponent(email) + '&sifre=eq.' + hashedPass);

        if (!users || users.length === 0) {
            showAuthError('login', 'E-posta veya şifre hatalı. Lütfen tekrar deneyin.');
            setAuthLoading('btnLogin', false);
            return;
        }

        var user = users[0];
        currentUser = { ad: user.ad, gmail: user.gmail };
        setAuthLoading('btnLogin', false);
        showMainApp();

    } catch (err) {
        var msg = err.message || '';
        if (msg.includes('Failed to fetch') || msg.includes('NetworkError')) {
            showAuthError('login', 'Bağlantı hatası. Lütfen dış kaynaklara erişim izni verin.');
        } else {
            showAuthError('login', 'Giriş hatası: ' + msg);
        }
        setAuthLoading('btnLogin', false);
    }
}

async function handleRegister() {
    hideAuthError('register');
    var name = document.getElementById('regName').value.trim();
    var email = document.getElementById('regEmail').value.trim().toLowerCase();
    var pass = document.getElementById('regPass').value;
    var passConfirm = document.getElementById('regPassConfirm').value;

    if (!name) { showAuthError('register', 'Lütfen adınızı girin.'); return; }
    if (name.length < 2) { showAuthError('register', 'Ad en az 2 karakter olmalıdır.'); return; }
    if (!email) { showAuthError('register', 'Lütfen Gmail adresinizi girin.'); return; }
    if (!validateEmail(email)) { showAuthError('register', 'Geçerli bir Gmail adresi girin.'); return; }
    if (!pass) { showAuthError('register', 'Lütfen bir şifre belirleyin.'); return; }
    if (pass.length < 6) { showAuthError('register', 'Şifre en az 6 karakter olmalıdır.'); return; }
    if (pass !== passConfirm) { showAuthError('register', 'Şifreler eşleşmiyor. Lütfen kontrol edin.'); return; }

    setAuthLoading('btnRegister', true);
    try {
        // Aynı email ile kayıtlı kullanıcı var mı kontrol et
        var existing = await SB.getRows(TABLE_NAME, 'select=gmail&gmail=eq.' + encodeURIComponent(email));

        if (existing && existing.length > 0) {
            showAuthError('register', 'Bu Gmail adresi zaten kayıtlı! Giriş ekranına yönlendiriliyorsunuz...');
            setAuthLoading('btnRegister', false);
            setTimeout(function() {
                switchAuth('login');
                document.getElementById('loginEmail').value = email;
            }, 1500);
            return;
        }

        var hashedPass = await hashPassword(pass);
        
        // Kullanıcıyı projeler tablosuna kaydet
        var newUser = await SB.insertRow(TABLE_NAME, {
            ad: name,
            gmail: email,
            sifre: hashedPass,
            proje_adi: 'Kullanıcı Kaydı',
            kategori: 'other',
            created_at: new Date().toISOString()
        });

        setAuthLoading('btnRegister', false);
        showToast('Kayıt başarılı! Otomatik giriş yapılıyor...', 'success');
        
        // Otomatik giriş yap
        currentUser = { ad: name, gmail: email };
        setTimeout(function() {
            showMainApp();
            showToast('Hoş geldiniz, ' + name + '!', 'success');
        }, 1000);

    } catch (err) {
        var errMsg = err.message || '';
        if (errMsg.includes('Failed to fetch') || errMsg.includes('NetworkError')) {
            showAuthError('register', 'Bağlantı hatası. Lütfen dış kaynaklara erişim izni verin.');
        } else if (errMsg.includes('duplicate') || errMsg.includes('unique')) {
            showAuthError('register', 'Bu Gmail adresi zaten kayıtlı!');
            setTimeout(function() { switchAuth('login'); }, 1500);
        } else {
            showAuthError('register', 'Kayıt hatası: ' + errMsg);
        }
        setAuthLoading('btnRegister', false);
    }
}

