async function loadGallery() {
    var refreshBtn = document.getElementById('btnRefresh');
    refreshBtn.classList.add('spinning');
    renderSkeletons();

    try {
        // Sadece gerçek projeleri getir (proje_adi 'Kullanıcı Kaydı' olmayanlar)
        projects = await SB.getRows(TABLE_NAME, 'select=id,proje_adi,ogrenci_adi,sinif,kategori,aciklama,malzemeler,foto_path,foto_url,created_at&order=created_at.desc');

        // Kullanıcı kayıtlarını filtrele (opsiyonel)
        projects = projects.filter(p => p.proje_adi !== 'Kullanıcı Kaydı');

        projects.forEach(function(p) {
            if (p.foto_path && !p.foto_url) {
                p.foto_url = SB.publicUrl(p.foto_path);
            }
        });

        document.getElementById('projectCount').textContent = projects.length;
        filterProjects();
    } catch (err) {
        var msg = err.message || '';
        if (msg.includes('Failed to fetch') || msg.includes('NetworkError')) {
            document.getElementById('galleryContent').innerHTML =
                '<div class="empty-state"><i class="fas fa-wifi"></i><h3>Bağlantı Hatası</h3>' +
                '<p>Dış kaynaklara erişim izni gerekiyor. Sayfayı yenileyip izin verin.</p></div>';
        } else if (msg.includes('does not exist')) {
            document.getElementById('galleryContent').innerHTML =
                '<div class="empty-state"><i class="fas fa-database"></i><h3>Tablo Bulunamadı</h3>' +
                '<p>Supabase\'de "' + TABLE_NAME + '" tablosunu oluşturmanız gerekiyor.</p></div>';
        } else {
            document.getElementById('galleryContent').innerHTML =
                '<div class="empty-state"><i class="fas fa-exclamation-triangle"></i><h3>Hata</h3>' +
                '<p>' + escapeHtml(msg) + '</p></div>';
        }
    }
    refreshBtn.classList.remove('spinning');
}

function filterProjects() {
    var searchTerm = document.getElementById('searchInput').value.trim().toLowerCase();
    var categoryFilter = document.getElementById('filterCategory').value;

    filteredProjects = projects.filter(function(p) {
        var matchSearch = !searchTerm ||
            (p.proje_adi && p.proje_adi.toLowerCase().indexOf(searchTerm) !== -1) ||
            (p.ogrenci_adi && p.ogrenci_adi.toLowerCase().indexOf(searchTerm) !== -1) ||
            (p.aciklama && p.aciklama.toLowerCase().indexOf(searchTerm) !== -1);
        var matchCategory = !categoryFilter || p.kategori === categoryFilter;
        return matchSearch && matchCategory;
    });

    renderGallery();
}

function renderGallery() {
    if (!filteredProjects || filteredProjects.length === 0) {
        if (projects.length > 0) {
            document.getElementById('galleryContent').innerHTML =
                '<div class="empty-state"><i class="fas fa-search"></i>' +
                '<h3>Sonuç Bulunamadı</h3>' +
                '<p>Arama kriterlerinize uygun proje bulunamadı. Filtreleri değiştirmeyi deneyin.</p></div>';
        } else {
            document.getElementById('galleryContent').innerHTML =
                '<div class="empty-state"><i class="fas fa-rocket"></i>' +
                '<h3>Henüz Proje Yüklenmemiş</h3>' +
                '<p>Şu an görüntülenecek proje bulunmuyor.</p></div>';
        }
        return;
    }

    var html = '<div class="gallery-grid">';
    filteredProjects.forEach(function(project, i) {
        var cat = CATEGORIES[project.kategori] || CATEGORIES.other;
        var imgSrc = project.foto_url || '';
        var dateStr = project.created_at ? project.created_at.split('T')[0] : '';

        html += '<div class="project-card" style="animation-delay:' + (i * 0.06) + 's" onclick="openProject(' + i + ')">' +
            (imgSrc
                ? '<img class="card-image" src="' + escapeHtml(imgSrc) + '" alt="' + escapeHtml(project.proje_adi) + '" loading="lazy" onerror="handleImgError(this)">'
                : '<div class="card-image-placeholder"><i class="fas fa-image"></i><span>Fotoğraf yok</span></div>') +
            '<div class="card-body">' +
                '<div class="card-title">' + escapeHtml(project.proje_adi) + '</div>' +
                '<div class="card-meta">' +
                    '<span class="card-badge ' + cat.cls + '">' + cat.label + '</span>' +
                    '<span class="card-date"><i class="far fa-calendar-alt"></i> ' + dateStr + '</span>' +
                '</div>' +
            '</div></div>';
    });
    html += '</div>';
    document.getElementById('galleryContent').innerHTML = html;
}

